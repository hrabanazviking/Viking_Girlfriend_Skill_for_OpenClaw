# .env.example — Sigrid Skill Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real API keys.
#
# Required keys are marked (REQUIRED).
# Optional keys show their defaults.

# ─── Primary Cloud Model (conscious-mind tier) ────────────────────────────────
# Used for: medium-complexity general conversation and reasoning.
# Recommended: gemini/gemini-2.0-flash, openai/gpt-4o, openai/gpt-4o-mini
PRIMARY_MODEL_NAME=gemini/gemini-2.0-flash          # (REQUIRED)
PRIMARY_API_KEY=your_primary_api_key_here            # (REQUIRED)

# ─── Secondary Cloud Model (deep-mind tier) ───────────────────────────────────
# Used for: high-complexity tasks, emotional depth, creative work.
# Recommended: openrouter/meta-llama/llama-3.1-405b-instruct
#              openrouter/anthropic/claude-3.5-sonnet
SECONDARY_MODEL_NAME=openrouter/meta-llama/llama-3.1-405b-instruct  # (REQUIRED)
SECONDARY_API_KEY=your_openrouter_api_key_here       # (REQUIRED)

# ─── Code-Specialized Model (code-mind tier) ──────────────────────────────────
# Used for: medium-complexity coding tasks (auto-detected).
# Recommended: openrouter/deepseek/deepseek-coder
#              openrouter/mistralai/codestral
#              openrouter/qwen/qwen2.5-coder-32b-instruct
CODE_MODEL_NAME=openrouter/deepseek/deepseek-coder  # (REQUIRED)
CODE_API_KEY=your_code_api_key_here                 # often same as SECONDARY_API_KEY

# ─── LiteLLM Proxy ────────────────────────────────────────────────────────────
# LiteLLM proxy translates all three cloud tiers through one OpenAI-compatible
# endpoint. Start with: litellm --config infrastructure/litellm_config.yaml
LITELLM_ENDPOINT=http://localhost:4000              # default

# ─── Ollama (subconscious tier) ───────────────────────────────────────────────
# Used for: low-complexity tasks, memory summarization, dream generation.
# Zero cost, fully local, absolute privacy.
# Pull the model with: ollama pull llama3
OLLAMA_ENDPOINT=http://localhost:11434              # default
OLLAMA_MODEL=llama3                                 # default

# ─── Sigrid Runtime ───────────────────────────────────────────────────────────
SIGRID_SKILL_ROOT=./viking_girlfriend_skill         # path to skill package root
SIGRID_LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR
SIGRID_MODE=openclaw                                # openclaw | terminal

# ─── Bio Engine (personalised cycle tracking) ─────────────────────────────────
# Set these to Sigrid's configured birth date and most recent cycle start date.
# Leave blank to use defaults (bio engine will use safe fallbacks).
SIGRID_BIRTH_DATE=2004-08-12
SIGRID_CYCLE_START_DATE=2026-03-01

# ─── Session ──────────────────────────────────────────────────────────────────
SIGRID_SESSION_ID=                                  # auto-generated if blank
SIGRID_PRIMARY_CONTACT=volmarr                      # primary relationship contact ID

# ─── Optional: OpenClaw host config ──────────────────────────────────────────
# Only needed if OpenClaw runs on a non-standard port.
# OPENCLAW_HOST=localhost
# OPENCLAW_PORT=3000
